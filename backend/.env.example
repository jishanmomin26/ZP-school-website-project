# MySQL Database URL (e.g. from PlanetScale)
DATABASE_URL="mysql://root:password@localhost:3306/zp_school"

# Firebase Admin SDK Configuration
# You can get these from the Firebase Console: Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-firebase-project-id.iam.gserviceaccount.com"
# For Vercel, replace newlines in the private key with \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key\n-----END PRIVATE KEY-----\n"

# API & Security
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
PORT="3000"
